<!-- Header styling -->
<style>

  header {
      position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 10;
  }

  header a {
    font-family: "Syne", sans-serif;
    font-weight: 700;
    font-size: larger;
    text-decoration: none;
    color: var(--color-accent);
    padding: 0.4rem 0.6rem;
  }
  

  .menu {
    display: flex;
    justify-content: center;
    margin: 2rem;
    gap: 10rem;
  }

  .menu li a:hover {
    display: inline-block;
    scale: 1.2;
    text-decoration: underline;
  }

  .menu li {
    list-style: none;
  }

  .dropdown {
    position: relative;
  }

  /* Gem dropdown ved default */
  .dropdown-menu {
    display: none;
    position: absolute;
    left: 0;
    background-color: var(--color-lightgreen);
    min-width: 180px;
    padding: 0.4rem 0.6rem;
    z-index: 100;
  }

  .dropdown-menu li a {
    display: block;
    padding: 0.4rem 0.6rem;
    text-decoration: none;
    color: var(--color-accent);
    font-weight: 700;
    white-space: nowrap;
  }

  .dropdown-menu li a:hover {
    scale: 1.2;
    text-decoration: underline;
    background-color: var(--color-lightgreen);
  }

  .dropdown:hover .dropdown-menu {
    display: block;
  }

  .dropdown:hover > a {
    background-color: var(--color-lightgreen);
  }

  .dropdown > a {
    padding: 0.4rem 0.6rem;
    display: inline-block;
  }

/* Burger menu */
.burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  position: absolute;
  top: 1.2rem;
  right: 1.5rem;
  z-index: 20;
}

.burger span {
  display: block;
  width: 28px;
  height: 3px;
  background-color: var(--color-accent);
  border-radius: 3px;
  transition: all 0.3s ease;
}

.burger.active span:nth-child(1) {
  transform: translateY(8px) rotate(45deg);
}
.burger.active span:nth-child(2) {
  opacity: 0;
}
.burger.active span:nth-child(3) {
  transform: translateY(-8px) rotate(-45deg);
}

@media (max-width: 768px) {
  .burger {
    display: flex;
  }

  nav {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    background-color: var(--color-lightgreen);
    padding-top: 4rem;
    z-index: 15;
  }

  nav.active {
    display: block;
  }

  .menu {
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    margin: 1rem;
  }

  .dropdown-menu {
    position: static;
    display: block;
    background-color: transparent;
    padding: 0;
    min-width: unset;
    text-align: center;
  }
}
</style>

<!-- Footer styling -->
<style>
  footer li {
    font-family: "Syne", sans-serif;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text);
    padding: 0.4rem 0.6rem;
  }

  footer a {
    text-decoration: none;
    color: var(--color-text);
  }

  footer ul {
    display: flex;
    justify-content: center;
    list-style: none;
    padding: 50px;
    padding-top: 200px;
    gap: 25rem;
    background: linear-gradient(180deg, rgba(236, 243, 215, 0) 0%, rgba(170, 217, 145, 1) 50%, rgba(170, 217, 145, 1) 100%);
  }

  .footer-index ul {
  background: linear-gradient(180deg,rgba(170, 217, 145, 1) 0%, rgba(236, 243, 215, 1) 100%);
}
</style>

<script>
  const burger = document.querySelector(".burger");
  const nav = document.querySelector("nav");

  burger.addEventListener("click", () => {
    burger.classList.toggle("active");
    nav.classList.toggle("active");
  });
</script>
