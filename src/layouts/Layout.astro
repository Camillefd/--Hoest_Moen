---
const { title } = Astro.props;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400..800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <ul class="menu">
          <li><a href="/"> <img src="/public/logo.webp" alt="logo" /></a></li>

          <li><a href="//">Billetter</a></li>

          <li class="dropdown">
            <a href="/program">Program</a>
            <ul class="dropdown-menu">
              <li><a href="">Tidligere program</a></li>
            </ul>
          </li>
          <li><a href="//">Bliv frivillig</a></li>

          <li class="dropdown">
            <a href="/omhoest">Om HØST</a>
            <ul class="dropdown-menu">
              <li><a href="">Find rundt & Camping</a></li>
              <li><a href="">Galleri</a></li>
            </ul>
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <ul>
        <li><a href="https://www.facebook.com/hoestmoen?locale=da_DK">Facebook</a></li>
        <li>info@hoestmoen.dk</li>
        <li><a href="https://www.instagram.com/hoestmoen/">Instagram</a></li>
      </ul>
    </footer>
  </body>
</html>

<!-- Header styling -->
<style>
 header a {
   font-family: "Syne", sans-serif;
   font-weight: 700;
   font-size: larger;
   text-decoration: none;
   color: var(--color-accent);
   padding: 0.4rem 0.6rem;
  }

.menu {
display: flex;
justify-content: center;
 margin: 2rem;
 gap: 10rem;
  }

  .menu li a:hover {
font-size:x-large;
text-decoration: underline;
padding: 0.4rem 0.6rem;
  }

  .menu li {
   list-style: none;
  }

.dropdown {
  position: relative;
}

/* Gem dropdown ved default */
.dropdown-menu {
  display: none;
  position: absolute;
  left: 0;
  background-color: var(--color-lightgreen);
  min-width: 180px;
  padding: 0.4rem 0.6rem;
  z-index: 100;
}

.dropdown-menu li a {
  display: block;
  padding: 0.4rem 0.6rem;
  text-decoration: none;
  color: var(--color-accent);
  font-weight: 700;
  white-space: nowrap;
}

.dropdown-menu li a:hover {
font-size:x-large;
text-decoration: underline;
}

.dropdown:hover .dropdown-menu {
  display: block;
}

.dropdown:hover > a {
  background-color: var(--color-lightgreen);
}

.dropdown > a {
   padding: 0.4rem 0.6rem;
  display: inline-block;
}

</style>

<!-- Footer styling -->
<style>
  footer {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

