---
const { kunstnere } = Astro.props;
import Button2 from "../components/Button2.astro";
---

<!-- <img src="/img/Majke.webp" alt="majke" /> -->
<article class="card_component" class:list={[kunstnere.reverse ? "reverse" : ""]}>
  <div class="card_image">
    <img src={`/img/${kunstnere.Billede}`} alt={kunstnere.Navn} />
  </div>
  <div class="card_content">
    <h2>{kunstnere.Navn}</h2>
    <p>{kunstnere.Langbeskrivelse}</p>
    <Button2 text="Læs mere" href="" />
  </div>
</article>

<style>
  .card_component {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    margin-bottom: 4rem;
  }

  /* Hvert andet card vender billedet til højre */
  .card_component.reverse {
    direction: rtl;
  }
  .card_component.reverse > * {
    direction: ltr;
  }

  .card_image img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
  }

  .card_content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
  }

  p {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .læs-mere:hover {
    background-color: #333;
  }
</style>
