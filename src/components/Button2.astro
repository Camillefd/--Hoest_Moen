---
const { text, href } = Astro.props;
---

<!-- Knap 2 med styling -->
 <a href={href} class="btn2">
  {text}
</a>

<style>
  .btn2 {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 120px;
    border-radius: 50%;  
    margin: 10px;
    background-color: var(--color-text);
    color:var(--color-background);
    text-decoration: none;
    font-family: "Syne", sans-serif;
    font-weight: 700;
  }

  .btn2:hover {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 2px solid  var(--color-lightgreen);  
    margin: 5px;
    background-color: var(--color-background);
    color: var(--color-lightgreen);
    text-decoration: none;
    font-family: "Syne", sans-serif;
    font-weight: 700;
  }
</style>